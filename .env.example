# Admin PIN for the protected /setup screen.
# Pick a PIN only the trusted event organizer(s) know. Do NOT use 1234
# or any other easily-guessed default. Copy this file to .env.local and
# fill in a real value before running the app.
#
# Reminder: this is a CLIENT-SIDE PIN bundled into the JS build. It is
# meant to keep casual guests out of /setup at a private family event,
# not to withstand a determined attacker. See README.md "Security
# limitations" for details.
VITE_ADMIN_PIN=change-this-pin
