# Server-only admin PIN for the protected /setup screen. This is read ONLY
# inside Vercel serverless functions (api/reveal/*) and is never bundled
# into client JavaScript — do NOT prefix it with VITE_. Pick a PIN only
# the trusted event organizer(s) know; do NOT use 1234 or leave it unset.
# Set this in your Vercel Project Settings -> Environment Variables (and
# in a local .env file for `vercel dev`), not by copying this file as-is.
ADMIN_PIN=change-this-pin

# Optional: secret used to sign short-lived admin session tokens issued
# after a correct PIN check. Defaults to ADMIN_PIN itself if unset, but
# setting a separate long random value here is recommended.
ADMIN_TOKEN_SECRET=

# Shared reveal storage (Redis). Connect a Redis/Upstash integration from
# the Vercel Marketplace to your project and these are usually populated
# automatically. Either naming scheme works:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# ...or, if your integration uses Upstash's own names instead:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
